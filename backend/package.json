{
  "name": "tacticboard-backend",
  "version": "1.0.0",
  "description": "TacticBoard API — Express + TypeScript + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
